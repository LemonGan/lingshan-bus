<!--list.wxml-->
<view class="list-container">
  <!-- 标签切换 -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all">全部</view>
    <view class="tab-item {{activeTab === 'urban' ? 'active' : ''}}" bindtap="switchTab" data-tab="urban">城区</view>
    <view class="tab-item {{activeTab === 'rural' ? 'active' : ''}}" bindtap="switchTab" data-tab="rural">城乡</view>
  </view>

  <!-- 线路列表 -->
  <scroll-view class="line-list" scroll-y="true">
    <view class="line-item" wx:for="{{filteredLines}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <text class="item-num {{item.type === '城区' ? 'urban' : 'rural'}}">{{item.id}}</text>
      <view class="item-info">
        <text class="item-route">{{item.start}} - {{item.end}}</text>
        <text class="item-time">{{item.time}} | {{item.interval}}</text>
      </view>
      <text class="item-price">{{item.price}}</text>
    </view>
    
    <view class="empty-tip" wx:if="{{filteredLines.length === 0}}">
      <text>暂无匹配的线路</text>
    </view>
  </scroll-view>
</view>