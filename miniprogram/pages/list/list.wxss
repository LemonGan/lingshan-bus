/* list.wxss */
.list-container { min-height: 100vh; }

.tab-bar {
  display: flex; background: var(--color-card);
  padding: 0 24rpx; border-bottom: 1rpx solid var(--color-border);
}
.tab-item {
  flex: 1; text-align: center; padding: 24rpx 0;
  font-size: var(--font-md); color: var(--color-text-secondary); position: relative;
}
.tab-item.active { color: var(--color-primary); font-weight: 600; }
.tab-item.active::after {
  content: ''; position: absolute; bottom: 0; left: 50%;
  transform: translateX(-50%); width: 48rpx; height: 6rpx;
  background: var(--color-primary); border-radius: 3rpx;
}

.line-list { padding: 20rpx; box-sizing: border-box; }

.line-item {
  display: flex; align-items: center; background: var(--color-card);
  border-radius: var(--radius-sm); padding: 24rpx 20rpx;
  margin-bottom: 12rpx; box-shadow: var(--shadow-sm);
}

.item-num { font-size: var(--font-lg); font-weight: 700; min-width: 90rpx; }
.item-num.urban { color: var(--color-primary); }
.item-num.rural { color: var(--color-warning); }

.item-info { flex: 1; margin-left: 16rpx; min-width: 0; }
.item-route {
  display: block; font-size: var(--font-md); color: var(--color-text-primary);
  font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.item-time {
  font-size: var(--font-xs); color: var(--color-text-hint); margin-top: 4rpx;
}

.item-price {
  font-size: var(--font-sm); color: var(--color-warning);
  background: var(--color-warning-bg); padding: 4rpx 12rpx;
  border-radius: var(--radius-sm); white-space: nowrap;
}

.empty-tip { text-align: center; padding: 100rpx; color: var(--color-text-hint); font-size: var(--font-md); }
