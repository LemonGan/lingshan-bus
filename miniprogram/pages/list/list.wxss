/* list.wxss */
page {
  background-color: #f5f7fa;
}

.container {
  padding: 30rpx;
  min-height: 100vh;
}

/* 标题 */
.header {
  padding: 20rpx 0 30rpx;
}

.title {
  font-size: 42rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.subtitle {
  font-size: 26rpx;
  color: #666;
  margin-top: 8rpx;
}

/* 筛选标签 */
.filter-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 30rpx;
  flex-wrap: wrap;
}

.filter-item {
  padding: 14rpx 28rpx;
  background-color: #fff;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.2s ease;
}

.filter-item.active {
  background: linear-gradient(135deg, #1677FF, #4096ff);
  color: #fff;
}

/* 线路卡片 */
.line-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.line-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.2s ease;
}

.line-card:active {
  transform: scale(0.99);
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.03);
}

.line-number {
  background: linear-gradient(135deg, #1677FF, #4096ff);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  padding: 18rpx 24rpx;
  border-radius: 14rpx;
  margin-right: 24rpx;
  min-width: 100rpx;
  text-align: center;
}

.line-info {
  flex: 1;
}

.line-name {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 500;
  margin-bottom: 10rpx;
}

.line-meta {
  display: flex;
  gap: 20rpx;
}

.line-time, .line-price {
  font-size: 24rpx;
  color: #888;
}

.line-price {
  color: #1677FF;
  font-weight: 500;
}

.line-arrow {
  color: #ccc;
  font-size: 32rpx;
  margin-left: 16rpx;
}