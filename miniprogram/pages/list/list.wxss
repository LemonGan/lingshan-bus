/* list.wxss */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  padding: 30rpx 0;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.line-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.line-item {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
}

.line-number {
  background-color: #1677FF;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  padding: 16rpx 24rpx;
  border-radius: 8rpx;
  margin-right: 24rpx;
}

.line-info {
  flex: 1;
}

.line-name {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.line-time {
  font-size: 26rpx;
  color: #999;
}