/* list.wxss */
page {
  background-color: #f8f9fa;
}

.container {
  padding: 30rpx;
  min-height: 100vh;
}

/* 标题 */
.header {
  padding: 20rpx 0 40rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.subtitle {
  font-size: 28rpx;
  color: #666;
  margin-top: 8rpx;
}

/* 线路卡片 */
.line-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.line-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s ease;
}

.line-card:active {
  transform: scale(0.99);
  box-shadow: 0 1rpx 8rpx rgba(0, 0, 0, 0.04);
}

.line-number {
  background: linear-gradient(135deg, #1677FF, #4096ff);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  padding: 20rpx 28rpx;
  border-radius: 16rpx;
  margin-right: 28rpx;
}

.line-info {
  flex: 1;
}

.line-name {
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.line-time {
  font-size: 26rpx;
  color: #888;
}

.line-arrow {
  color: #ccc;
  font-size: 32rpx;
}