/* list.wxss */
page { background: #f5f7fa; }
.list-container { min-height: 100vh; }

.tab-bar { display: flex; background: #fff; padding: 0 24rpx; border-bottom: 1rpx solid #eee; }
.tab-item { flex: 1; text-align: center; padding: 24rpx 0; font-size: 28rpx; color: #666; position: relative; }
.tab-item.active { color: #1677FF; font-weight: 600; }
.tab-item.active::after { content: ''; position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 48rpx; height: 6rpx; background: #1677FF; border-radius: 3rpx; }

.line-list { padding: 20rpx; box-sizing: border-box; }

.line-item { display: flex; align-items: center; background: #fff; border-radius: 12rpx; padding: 20rpx; margin-bottom: 12rpx; box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.06); }

.item-num { font-size: 30rpx; font-weight: 700; min-width: 90rpx; }
.item-num.urban { color: #1677FF; }
.item-num.rural { color: #f59e0b; }

.item-info { flex: 1; margin-left: 16rpx; min-width: 0; }
.item-route { display: block; font-size: 26rpx; color: #333; font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.item-time { font-size: 22rpx; color: #999; margin-top: 4rpx; }

.item-price { font-size: 22rpx; color: #f59e0b; background: #fef3cd; padding: 4rpx 12rpx; border-radius: 12rpx; white-space: nowrap; }

.empty-tip { text-align: center; padding: 100rpx; color: #999; }