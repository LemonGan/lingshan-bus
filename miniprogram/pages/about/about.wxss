/* about.wxss */
page { background: #f5f7fa; min-height: 100vh; }
.container { padding: 24rpx; }

.header { text-align: center; padding: 40rpx 0; }
.app-name { font-size: 48rpx; font-weight: 700; color: #1677FF; }
.version { font-size: 24rpx; color: #999; margin-left: 12rpx; }

.section { background: #fff; border-radius: 16rpx; padding: 30rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); }
.section-title { font-size: 30rpx; font-weight: 600; color: #333; margin-bottom: 20rpx; display: block; }
.desc { font-size: 26rpx; color: #666; line-height: 1.8; }

.social-list { margin-top: 10rpx; }
.social-item {
  display: flex; align-items: center;
  padding: 20rpx 0; border-bottom: 1rpx solid #f0f0f0;
}
.social-item:last-child { border-bottom: none; }
.social-icon { font-size: 40rpx; margin-right: 20rpx; }
.social-info { flex: 1; }
.social-platform { font-size: 24rpx; color: #999; display: block; }
.social-name { font-size: 28rpx; color: #333; font-weight: 500; margin-top: 4rpx; }
.copy-btn {
  font-size: 24rpx; color: #1677FF;
  border: 1rpx solid #1677FF; border-radius: 30rpx;
  padding: 8rpx 24rpx;
}

.footer { text-align: center; padding: 30rpx 0; padding-bottom: 40rpx; }
.footer-text { font-size: 22rpx; color: #ccc; }
