<view class="container">
  <view class="header">
    <text class="app-name">{{appName}}</text>
    <text class="version">v{{version}}</text>
  </view>
  
  <view class="section">
    <text class="desc">{{desc}}</text>
  </view>
  
  <view class="section">
    <text class="section-title">📢 关注我</text>
    <view class="social-list">
      <view class="social-item" wx:for="{{social}}" wx:key="index">
        <text class="social-icon">{{item.icon}}</text>
        <view class="social-info">
          <text class="social-platform">{{item.platform}}</text>
          <text class="social-name">{{item.name}}</text>
        </view>
        <text class="copy-btn" bindtap="copyAccount" data-text="{{item.name}}">复制</text>
      </view>
    </view>
  </view>
  
  <view class="section">
    <text class="section-title">📧 联系合作</text>
    <view class="contact-box">
      <text class="contact-text">{{contact}}</text>
      <view class="contact-item">
        <text class="contact-label">📩 小红书/抖音</text>
        <text class="contact-value">私信留言</text>
      </view>
      <view class="contact-item">
        <text class="contact-label">🤝 商务合作</text>
        <text class="contact-value">私信详谈</text>
      </view>
    </view>
  </view>
  
  <view class="footer">
    <text class="footer-text">灵山人自己的公交工具 🚌</text>
  </view>
</view>
