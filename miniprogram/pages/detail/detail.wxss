/* pages/detail/detail.wxss */

.detail-container { min-height: 100vh; display: flex; flex-direction: column; }

/* ===== 顶部渐变头 ===== */
.detail-header {
  background: linear-gradient(135deg, #1677FF 0%, #0958d9 100%);
  padding: 40rpx 32rpx 32rpx; color: #fff;
}
.dh-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.dh-line-info { display: flex; align-items: center; gap: 14rpx; }
.dh-line-num { font-size: 52rpx; font-weight: 700; }
.dh-line-num.urban { color: #fff; }
.dh-line-num.rural { color: #ffd666; }
.dh-line-info .badge {
  font-size: var(--font-xs); padding: 6rpx 16rpx; border-radius: 20rpx;
  font-weight: 500;
}
.dh-line-info .badge-urban { background: rgba(255,255,255,0.2); color: #fff; }
.dh-line-info .badge-rural { background: rgba(255,255,255,0.2); color: #ffd666; }
.dh-price {
  font-size: var(--font-xl); font-weight: 700; color: #ffd666;
  background: rgba(255,255,255,0.15); padding: 8rpx 24rpx; border-radius: var(--radius-round);
}

/* 方向切换 */
.direction-switch {
  display: flex; flex-direction: column; align-items: center;
  background: rgba(255,255,255,0.12); border-radius: var(--radius-md);
  padding: 20rpx 24rpx; margin-bottom: 24rpx;
}
.dir-label { font-size: var(--font-xs); color: rgba(255,255,255,0.55); }
.dir-stations { display: flex; align-items: center; margin: 10rpx 0; width: 100%; }
.dir-name { font-size: var(--font-md); font-weight: 600; flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.dir-name-left { text-align: right; padding-right: 16rpx; }
.dir-name-right { text-align: left; padding-left: 16rpx; }
.dir-swap-btn {
  width: 60rpx; height: 60rpx; background: #fff; border-radius: 50%;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.1);
}
.swap-icon { font-size: 32rpx; color: var(--color-primary); font-weight: 700; }
.dir-hint { font-size: var(--font-xs); color: rgba(255,255,255,0.4); }

/* 关键信息三列 */
.dh-stats { display: flex; align-items: center; }
.stat-item { flex: 1; text-align: center; }
.stat-value { display: block; font-size: var(--font-lg); font-weight: 700; margin-bottom: 4rpx; }
.stat-label { font-size: var(--font-xs); opacity: 0.65; }
.stat-divider { width: 1rpx; height: 40rpx; background: rgba(255,255,255,0.2); }

/* ===== 运营状态卡片 ===== */
.status-card {
  display: flex; align-items: center; margin: -16rpx 24rpx 24rpx;
  background: var(--color-card); border-radius: var(--radius-md);
  padding: 28rpx 32rpx; box-shadow: var(--shadow-md);
}
.sc-left { text-align: center; min-width: 160rpx; }
.sc-time { display: block; font-size: var(--font-xxl); font-weight: 700; color: var(--color-text-primary); }
.sc-label { font-size: var(--font-xs); color: var(--color-text-hint); margin-top: 4rpx; }
.sc-divider-v { width: 1rpx; height: 60rpx; background: #eee; margin: 0 28rpx; flex-shrink: 0; }
.sc-right { flex: 1; }

.sc-status {
  display: inline-flex; align-items: center; padding: 8rpx 18rpx;
  border-radius: 20rpx; font-size: var(--font-sm); font-weight: 500;
}
.sc-status.operating { background: var(--color-success-bg); color: var(--color-success); }
.sc-status.off-duty  { background: var(--color-danger-bg); color: var(--color-danger); }
.sc-dot { width: 12rpx; height: 12rpx; border-radius: 50%; margin-right: 8rpx; }
.sc-status.operating .sc-dot { background: var(--color-success); animation: pulse 2s infinite; }
.sc-status.off-duty .sc-dot  { background: var(--color-danger); }
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}
.sc-hint { display: block; font-size: var(--font-xs); color: var(--color-text-hint); margin-top: 8rpx; }
.sc-hint.off { color: var(--color-danger); }

/* ===== 站点时间轴 ===== */
.timeline-card {
  margin: 0 24rpx 24rpx; background: var(--color-card);
  border-radius: var(--radius-lg); padding: 28rpx 24rpx; box-shadow: var(--shadow-sm);
}
.timeline-card.fading-out {
  opacity: 0; transform: translateY(10rpx);
  transition: opacity 0.2s ease, transform 0.2s ease;
}
.timeline-card.fading-in {
  opacity: 1; transform: translateY(0);
  transition: opacity 0.25s ease, transform 0.25s ease;
}
.tl-header {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 28rpx; padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.tl-title { font-size: var(--font-lg); font-weight: 600; color: var(--color-text-primary); }
.tl-count  { font-size: var(--font-sm); color: var(--color-text-hint); }

/* 时间轴列表 */
.timeline { padding-left: 8rpx; }
.tl-item { display: flex; min-height: 80rpx; }
.tl-item:last-child { min-height: auto; }

/* 左侧圆点 + 线段 */
.tl-left { width: 48rpx; flex-shrink: 0; }
.tl-dot-wrap { display: flex; flex-direction: column; align-items: center; height: 100%; }
.tl-dot {
  width: 24rpx; height: 24rpx; border-radius: 50%; background: var(--color-primary);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 0 0 5rpx rgba(22,119,255,0.12);
  flex-shrink: 0; z-index: 1;
}
.tl-dot-inner { width: 10rpx; height: 10rpx; border-radius: 50%; background: #fff; }
.tl-dot.start-dot { background: var(--color-success); box-shadow: 0 0 0 5rpx rgba(82,196,26,0.15); }
.tl-dot.end-dot   { background: var(--color-danger); box-shadow: 0 0 0 5rpx rgba(255,77,79,0.15); }
.tl-line {
  width: 3rpx; flex: 1; min-height: 26rpx;
  background: linear-gradient(180deg, #d6e4ff 0%, #e8e8e8 100%);
}

/* 右侧站点 */
.tl-right { flex: 1; padding-bottom: 28rpx; margin-left: 16rpx; }
.tl-item:last-child .tl-right { padding-bottom: 0; }
.tl-station-row { display: flex; align-items: center; margin-bottom: 6rpx; }
.tl-station-name { font-size: var(--font-md); font-weight: 500; color: var(--color-text-primary); }
.tl-station-name.is-start { color: var(--color-success); font-weight: 600; }
.tl-station-name.is-end   { color: var(--color-danger); font-weight: 600; }
.tl-badge-start {
  font-size: 18rpx; margin-left: 10rpx; padding: 2rpx 10rpx;
  background: var(--color-success-bg); color: var(--color-success);
  border-radius: var(--radius-sm); font-weight: 500;
}
.tl-badge-end {
  font-size: 18rpx; margin-left: 10rpx; padding: 2rpx 10rpx;
  background: var(--color-danger-bg); color: var(--color-danger);
  border-radius: var(--radius-sm); font-weight: 500;
}

.tl-arrival { display: flex; align-items: baseline; }
.tl-arrival-time { font-size: var(--font-lg); font-weight: 700; color: var(--color-primary); }
.tl-arrival-label { font-size: var(--font-xs); color: var(--color-text-hint); margin-left: 6rpx; }
.tl-arrival-estimate { font-size: var(--font-sm); color: var(--color-text-secondary); }
.tl-off-text { font-size: var(--font-sm); color: var(--color-text-hint); }

/* ===== 站点弹窗 ===== */
.station-popup-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45); z-index: 200;
  display: flex; align-items: center; justify-content: center;
  animation: maskIn 0.25s ease;
}
@keyframes maskIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}
.station-popup {
  width: 520rpx; background: #fff; border-radius: var(--radius-lg);
  padding: 48rpx 40rpx 36rpx; text-align: center;
  animation: popupIn 0.3s ease;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.15);
}
@keyframes popupIn {
  from { opacity: 0; transform: scale(0.85) translateY(20rpx); }
  to   { opacity: 1; transform: scale(1) translateY(0); }
}
.popup-line {
  width: 60rpx; height: 5rpx; background: #ddd;
  border-radius: 3rpx; margin: 0 auto 24rpx;
}
.popup-name {
  display: block; font-size: var(--font-xl); font-weight: 700;
  color: var(--color-text-primary); margin-bottom: 20rpx;
}
.popup-info { margin-bottom: 28rpx; }
.popup-time {
  display: block; font-size: 56rpx; font-weight: 700; color: var(--color-primary);
}
.popup-label { font-size: var(--font-sm); color: var(--color-text-hint); }
.popup-estimate { font-size: var(--font-lg); color: var(--color-text-secondary); font-weight: 500; }
.popup-off { font-size: var(--font-md); color: var(--color-danger); }
.popup-btn {
  width: 100%; background: var(--color-primary); color: #fff;
  font-size: var(--font-md); font-weight: 600;
  border-radius: var(--radius-round); padding: 18rpx 0;
}
