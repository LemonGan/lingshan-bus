/* pages/detail/detail.wxss */
page { background: #f5f7fa; }
.detail-container {
  min-height: 100vh;
  padding-bottom: 80rpx;
}

.header { background: linear-gradient(135deg, #1677FF 0%, #0d5dc7 100%); padding: 32rpx; color: #fff; }
.line-title { display: flex; align-items: center; margin-bottom: 20rpx; }
.line-num { font-size: 48rpx; font-weight: 700; margin-right: 16rpx; }
.line-type { font-size: 24rpx; background: rgba(255,255,255,0.2); padding: 6rpx 16rpx; border-radius: 20rpx; }

/* 方向切换 */
.direction-switch { 
  display: flex; align-items: center; justify-content: space-between; 
  background: rgba(255,255,255,0.15); border-radius: 16rpx; padding: 16rpx 20rpx; margin-bottom: 20rpx; 
}
.dir-station { font-size: 26rpx; font-weight: 500; flex: 1; text-align: center; }
.dir-btn { 
  display: flex; align-items: center; justify-content: center; 
  background: #fff; color: #1677FF; padding: 10rpx 24rpx; border-radius: 30rpx; font-size: 24rpx; font-weight: 600; 
}
.dir-icon { margin-left: 8rpx; font-size: 28rpx; }

.info-row { display: flex; justify-content: space-around; background: rgba(255,255,255,0.1); border-radius: 12rpx; padding: 16rpx 0; }
.info-item { text-align: center; }
.info-label { display: block; font-size: 22rpx; opacity: 0.8; margin-bottom: 4rpx; }
.info-value { font-size: 26rpx; font-weight: 600; }
.info-value.price { color: #ffd93d; }

.time-status { 
  display: flex; justify-content: space-between; align-items: center; 
  margin: 24rpx; padding: 20rpx 24rpx; background: #fff; border-radius: 16rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); 
}
.current-time { display: flex; align-items: center; }
.time-label { font-size: 24rpx; color: #666; margin-right: 12rpx; }
.time-value { font-size: 36rpx; font-weight: 700; color: #333; }

.operating-status { display: flex; align-items: center; padding: 8rpx 16rpx; border-radius: 20rpx; font-size: 24rpx; }
.operating-status.operating { background: #e6f7ed; color: #52c41a; }
.operating-status.off-duty { background: #fff1f0; color: #ff4d4f; }
.status-dot { width: 12rpx; height: 12rpx; border-radius: 50%; margin-right: 8rpx; }
.operating-status.operating .status-dot { background: #52c41a; }
.operating-status.off-duty .status-dot { background: #ff4d4f; }

.station-timeline { background: #fff; margin: 0 24rpx 24rpx; border-radius: 20rpx; padding: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.timeline-title { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; padding-bottom: 16rpx; border-bottom: 1rpx solid #eee; }
.timeline-title text:first-child { font-size: 32rpx; font-weight: 600; color: #333; }
.station-count { font-size: 24rpx; color: #999; }

.timeline-list { padding-left: 16rpx; }
.timeline-item { display: flex; padding-bottom: 24rpx; }
.timeline-item:last-child { padding-bottom: 0; }

.timeline-dot { display: flex; flex-direction: column; align-items: center; margin-right: 20rpx; }
.dot { width: 20rpx; height: 20rpx; background: #1677FF; border-radius: 50%; border: 4rpx solid #fff; box-shadow: 0 0 0 4rpx #d6e4ff; z-index: 1; }
.timeline-item.start .dot { background: #52c41a; box-shadow: 0 0 0 4rpx #d9f7be; }
.timeline-item.end .dot { background: #ff4d4f; box-shadow: 0 0 0 4rpx #ffccc7; }
.dot-line { width: 4rpx; flex: 1; background: #d6e4ff; margin-top: -4rpx; }

.station-info { flex: 1; display: flex; justify-content: space-between; align-items: center; min-height: 60rpx; }
.station-name { font-size: 28rpx; color: #333; font-weight: 500; }
.timeline-item.start .station-name { color: #52c41a; font-weight: 600; }
.timeline-item.end .station-name { color: #ff4d4f; font-weight: 600; }

.station-arrival { display: flex; align-items: center; min-width: 140rpx; justify-content: flex-end; }
.arrival-time { font-size: 28rpx; font-weight: 600; color: #1677FF; }
.arrival-next { font-size: 22rpx; color: #999; margin-left: 4rpx; }
.arrival-closed { font-size: 22rpx; color: #ff4d4f; }