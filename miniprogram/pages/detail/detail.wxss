/* detail.wxss */
page {
  background-color: #f8f9fa;
}

.container {
  padding: 30rpx;
  min-height: 100vh;
}

/* 头部卡片 */
.header {
  background: linear-gradient(135deg, #1677FF, #4096ff);
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(22, 119, 255, 0.3);
}

.line-number {
  color: #fff;
  font-size: 56rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.line-name {
  color: rgba(255, 255, 255, 0.9);
  font-size: 34rpx;
}

/* 信息卡片 */
.info-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.info-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
}

.info-item {
  text-align: center;
}

.info-label {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 12rpx;
}

.info-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

/* 站点 */
.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #1677FF;
}

.stations {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 24rpx 36rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.station-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.station-item:last-child {
  border-bottom: none;
}

.station-dot {
  width: 20rpx;
  height: 20rpx;
  background: linear-gradient(135deg, #1677FF, #4096ff);
  border-radius: 50%;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.station-dot.first {
  width: 28rpx;
  height: 28rpx;
  box-shadow: 0 0 16rpx rgba(22, 119, 255, 0.4);
}

.station-dot.last {
  background: linear-gradient(135deg, #ff6b6b, #ff8e8e);
}

.station-name {
  font-size: 30rpx;
  color: #333;
}

/* 时刻表 */
.schedule-section {
  margin-top: 20rpx;
}

.schedule {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.schedule-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1677FF;
  margin-bottom: 20rpx;
  text-align: center;
}

.time-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 16rpx;
}

.time-item {
  background-color: #f5f7fa;
  padding: 16rpx 8rpx;
  border-radius: 12rpx;
  text-align: center;
  font-size: 26rpx;
  color: #333;
}