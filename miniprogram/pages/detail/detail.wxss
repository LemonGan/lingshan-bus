/* detail.wxss */
page {
  background-color: #f5f7fa;
}

.container {
  padding: 30rpx;
  min-height: 100vh;
}

/* 头部卡片 */
.header {
  background: linear-gradient(135deg, #1677FF, #4096ff);
  border-radius: 28rpx;
  padding: 44rpx 36rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 28rpx rgba(22, 119, 255, 0.28);
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.line-number {
  color: #fff;
  font-size: 52rpx;
  font-weight: 700;
}

.line-type {
  background: rgba(255,255,255,0.2);
  color: #fff;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
}

.line-name {
  color: rgba(255,255,255,0.95);
  font-size: 32rpx;
  font-weight: 500;
  line-height: 1.4;
}

/* 信息网格 */
.info-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.info-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.info-item {
  text-align: center;
}

.info-label {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 10rpx;
}

.info-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.info-value.highlight {
  color: #1677FF;
}

/* 站点 */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 5rpx solid #1677FF;
}

.stations {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.station-item {
  display: flex;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.station-item:last-child {
  border-bottom: none;
}

.station-dot {
  width: 18rpx;
  height: 18rpx;
  background: linear-gradient(135deg, #1677FF, #4096ff);
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.station-dot.start {
  width: 24rpx;
  height: 24rpx;
  box-shadow: 0 0 14rpx rgba(22, 119, 255, 0.4);
}

.station-dot.end {
  background: linear-gradient(135deg, #ff6b6b, #ff8e8e);
}

.station-name {
  font-size: 28rpx;
  color: #333;
}

/* 备注 */
.notes {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.note-item {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.note-item:last-child {
  margin-bottom: 0;
}

.note-icon {
  margin-right: 8rpx;
}