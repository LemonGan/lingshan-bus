/* index.wxss */
page {
  background-color: #f5f7fa;
}

.container {
  padding: 30rpx;
  min-height: 100vh;
}

/* 搜索框 */
.search-box {
  background-color: #fff;
  border-radius: 50rpx;
  padding: 24rpx 36rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(22, 119, 255, 0.12);
  margin-bottom: 40rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.search-placeholder {
  color: #999;
}

/* 标题 */
.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.section-line {
  width: 40rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #1677FF, #4096ff);
  border-radius: 3rpx;
  margin-left: 12rpx;
}

/* 线路卡片 */
.line-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.line-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.2s ease;
  display: flex;
  flex-direction: column;
}

.line-card:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.03);
}

.line-number-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.line-number {
  background: linear-gradient(135deg, #1677FF, #4096ff);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  padding: 10rpx 18rpx;
  border-radius: 10rpx;
}

.line-type-tag {
  font-size: 22rpx;
  color: #1677FF;
  background: rgba(22, 119, 255, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.line-name {
  font-size: 26rpx;
  color: #1a1a1a;
  font-weight: 500;
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.line-time {
  font-size: 22rpx;
  color: #888;
}

/* 分类标签 */
.category-list {
  display: flex;
  gap: 20rpx;
}

.category-item {
  flex: 1;
  background: linear-gradient(135deg, #1677FF, #4096ff);
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  transition: all 0.2s ease;
}

.category-item:active {
  transform: scale(0.98);
}

.category-name {
  display: block;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.category-desc {
  display: block;
  color: rgba(255,255,255,0.8);
  font-size: 22rpx;
}