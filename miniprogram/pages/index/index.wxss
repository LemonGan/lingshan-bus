/* pages/index/index.wxss */

/* ===== Hero ===== */
.hero-section {
  position: relative;
  margin: 24rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
}
.hero-bg {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(135deg, #1677FF 0%, #4096ff 40%, #69b1ff 100%);
}
.hero-content {
  position: relative; z-index: 1;
  padding: 48rpx 36rpx 40rpx;
  display: flex; flex-direction: column; align-items: center;
}
.hero-title {
  font-size: 48rpx; font-weight: 700; color: #fff;
  letter-spacing: 4rpx; margin-bottom: 8rpx;
}
.hero-subtitle {
  font-size: var(--font-sm); color: rgba(255,255,255,0.75);
  margin-bottom: 32rpx;
}
.hero-search {
  width: 100%; display: flex; align-items: center;
  background: rgba(255,255,255,0.95); border-radius: var(--radius-round);
  padding: 18rpx 28rpx; box-sizing: border-box;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
}
.hero-search .search-icon { font-size: 32rpx; margin-right: 14rpx; opacity: 0.5; }
.hero-search .search-input { flex: 1; font-size: var(--font-md); color: var(--color-text-primary); }
.search-placeholder { color: #bbb; }

/* ===== 快速入口 ===== */
.quick-actions {
  display: flex; gap: 20rpx; padding: 0 24rpx; margin-bottom: 8rpx;
}
.action-item {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  background: var(--color-card); border-radius: var(--radius-md);
  padding: 28rpx 12rpx; box-shadow: var(--shadow-sm); transition: all 0.2s;
}
.action-item:active { transform: scale(0.96); box-shadow: var(--shadow-md); }
.action-icon {
  font-size: 48rpx; margin-bottom: 10rpx;
  width: 80rpx; height: 80rpx; display: flex; align-items: center; justify-content: center;
  border-radius: 50%;
}
.action-urban { background: #e6f4ff; }
.action-rural { background: #fef3cd; }
.action-all  { background: #f0f5ff; }
.action-label { font-size: var(--font-sm); color: var(--color-text-secondary); font-weight: 500; }

/* ===== 通用 Section ===== */
.section { margin: 24rpx 24rpx 0; }
.section-header {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 20rpx;
}
.section-title-group { display: flex; align-items: center; }
.section-dot {
  width: 10rpx; height: 28rpx; border-radius: 5rpx;
  background: var(--color-primary); margin-right: 12rpx;
}
.section-dot.urban-dot { background: var(--color-primary); }
.section-dot.rural-dot { background: var(--color-warning); }
.section-title { font-size: var(--font-lg); font-weight: 600; color: var(--color-text-primary); }
.more-btn { font-size: var(--font-sm); color: var(--color-text-hint); }

/* ===== 热门线路卡片 ===== */
.line-grid { display: flex; flex-wrap: wrap; gap: 20rpx; }
.line-card {
  width: calc(50% - 10rpx); background: var(--color-card);
  border-radius: var(--radius-md); padding: 24rpx;
  box-sizing: border-box; box-shadow: var(--shadow-sm);
  position: relative; overflow: hidden; transition: transform 0.15s;
}
.line-card:active { transform: scale(0.97); }
.card-badge {
  position: absolute; top: 0; right: 0;
  padding: 6rpx 18rpx; font-size: var(--font-xs);
  border-radius: 0 0 0 16rpx; font-weight: 500;
}
.card-badge.badge-urban { background: var(--color-primary-light); color: var(--color-primary); }
.card-badge.badge-rural { background: var(--color-warning-bg); color: var(--color-warning); }
.card-id-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14rpx; }
.line-number { font-size: 40rpx; font-weight: 700; }
.line-number.urban { color: var(--color-primary); }
.line-number.rural { color: var(--color-warning); }
.card-price {
  font-size: var(--font-sm); font-weight: 600; color: var(--color-warning);
  background: var(--color-warning-bg); padding: 4rpx 14rpx; border-radius: 20rpx;
}
.card-route { display: flex; align-items: center; margin-bottom: 14rpx; }
.route-from, .route-to { font-size: var(--font-sm); color: var(--color-text-primary); font-weight: 500; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.route-arrow { font-size: 20rpx; color: var(--color-text-hint); margin: 0 8rpx; flex-shrink: 0; }
.card-meta { display: flex; flex-direction: column; gap: 4rpx; }
.meta-item { font-size: var(--font-xs); color: var(--color-text-hint); }

/* ===== 线路列表 ===== */
.line-list-wrapper {
  background: var(--color-card); border-radius: var(--radius-md);
  overflow: hidden; box-shadow: var(--shadow-sm);
}
.line-list-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 24rpx; border-bottom: 1rpx solid #f5f5f5;
  transition: background 0.15s;
}
.line-list-item:active { background: #fafafa; }
.line-list-item:last-child { border-bottom: none; }
.ll-left { display: flex; align-items: center; flex: 1; min-width: 0; }
.ll-num { font-size: var(--font-xl); font-weight: 700; min-width: 90rpx; }
.ll-num.urban { color: var(--color-primary); }
.ll-num.rural { color: var(--color-warning); }
.ll-route { margin-left: 16rpx; flex: 1; min-width: 0; }
.ll-route-text { display: block; font-size: var(--font-md); color: var(--color-text-primary); font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ll-meta { display: block; font-size: var(--font-xs); color: var(--color-text-hint); margin-top: 4rpx; }
.ll-right { flex-shrink: 0; }

/* 移除旧的底部导航样式 - 改用 tabBar */
