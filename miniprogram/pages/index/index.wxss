/* index.wxss */
page {
  background-color: #f8f9fa;
}

.container {
  padding: 30rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 搜索框 */
.search-box {
  background-color: #fff;
  border-radius: 50rpx;
  padding: 24rpx 36rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 40rpx;
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 20rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.search-placeholder {
  color: #999;
}

/* 标题 */
.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.section-line {
  width: 48rpx;
  height: 8rpx;
  background: linear-gradient(90deg, #1677FF, #4096ff);
  border-radius: 4rpx;
  margin-left: 16rpx;
}

/* 线路卡片 */
.line-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.line-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s ease;
}

.line-card:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 8rpx rgba(0, 0, 0, 0.04);
}

.line-number-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.line-number {
  background: linear-gradient(135deg, #1677FF, #4096ff);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
}

.line-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  line-height: 1.4;
}

/* 图标 */
.icon {
  width: 100%;
  height: 100%;
}