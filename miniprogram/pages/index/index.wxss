/* index.wxss */
page { background: #f5f7fa; min-height: 100vh; }
.container { position: relative; min-height: 100vh; padding-bottom: 100rpx; }
.content-wrap { padding: 24rpx; padding-bottom: 120rpx; }

.search-box {
  display: flex; align-items: center; background: #fff;
  border-radius: 50rpx; padding: 20rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}
.search-icon { font-size: 32rpx; margin-right: 16rpx; }
.search-input { flex: 1; font-size: 28rpx; }
.search-placeholder { color: #999; }

.section-header {
  display: flex; justify-content: space-between; align-items: center;
  margin: 36rpx 0 20rpx;
}
.section-title { font-size: 34rpx; font-weight: 600; color: #333; }
.more-btn { font-size: 26rpx; color: #999; }

/* 热门线路 */
.line-grid {
  display: flex; flex-wrap: wrap; gap: 20rpx;
}
.line-card {
  width: calc(50% - 10rpx); background: #fff; border-radius: 16rpx;
  padding: 24rpx; box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.line-number-row { margin-bottom: 12rpx; }
.line-number { font-size: 36rpx; font-weight: 700; }
.line-number.urban { color: #1677FF; }
.line-number.rural { color: #f59e0b; }
.line-name { display: block; font-size: 26rpx; color: #333; margin-bottom: 8rpx; }
.line-time { font-size: 22rpx; color: #999; }

/* 线路列表 */
.line-list { background: #fff; border-radius: 16rpx; overflow: hidden; }
.line-item {
  display: flex; align-items: center; padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.line-item:last-child { border-bottom: none; }
.item-num { font-size: 32rpx; font-weight: 700; min-width: 100rpx; }
.item-num.urban { color: #1677FF; }
.item-num.rural { color: #f59e0b; }
.item-info { flex: 1; margin-left: 20rpx; }
.item-route { display: block; font-size: 28rpx; color: #333; font-weight: 500; }
.item-time { font-size: 22rpx; color: #999; margin-top: 6rpx; }
.item-price { font-size: 24rpx; color: #f59e0b; background: #fef3cd; padding: 4rpx 12rpx; border-radius: 8rpx; }

/* 底部占位 */
.bottom-placeholder { height: 100rpx; }

/* 底部导航 */
.bottom-nav {
  position: fixed; left: 0; right: 0; bottom: 0;
  display: flex; background: #fff;
  border-top: 1rpx solid #eee;
  padding: 16rpx 0;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  z-index: 100;
}
.nav-item {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  color: #999;
}
.nav-item.active { color: #1677FF; }
.nav-icon { font-size: 40rpx; }
.nav-text { font-size: 22rpx; margin-top: 4rpx; }