<view class="container">
  <!-- 内容区域 -->
  <view class="content-wrap">
    <!-- 搜索框 -->
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input 
        class="search-input" 
        placeholder="搜索线路或站点" 
        placeholder-class="search-placeholder"
        bindinput="onSearchInput"
        bindconfirm="onSearch"
        confirm-type="search"
      />
    </view>
    
    <!-- 热门线路 -->
    <view class="section-header">
      <text class="section-title">热门线路</text>
    </view>
    
    <view class="line-grid">
      <view class="line-card" wx:for="{{hotLines}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <view class="line-number-row">
          <text class="line-number {{item.type === '城区' ? 'urban' : 'rural'}}">{{item.id}}</text>
        </view>
        <text class="line-name">{{item.start}} - {{item.end}}</text>
        <text class="line-time">{{item.time}} | {{item.price}}</text>
      </view>
    </view>
    
    <!-- 城区公交 -->
    <view class="section-header">
      <text class="section-title">城区公交</text>
      <text class="more-btn" bindtap="goToList" data-type="城区">更多 ></text>
    </view>
    
    <view class="line-list">
      <view class="line-item" wx:for="{{urbanLines}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <text class="item-num {{item.type === '城区' ? 'urban' : 'rural'}}">{{item.id}}</text>
        <view class="item-info">
          <text class="item-route">{{item.start}} - {{item.end}}</text>
          <text class="item-time">{{item.time}}</text>
        </view>
        <text class="item-price">{{item.price}}</text>
      </view>
    </view>
    
    <!-- 城乡公交 -->
    <view class="section-header">
      <text class="section-title">城乡公交</text>
      <text class="more-btn" bindtap="goToList" data-type="城乡">更多 ></text>
    </view>
    
    <view class="line-list">
      <view class="line-item" wx:for="{{ruralLines}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <text class="item-num {{item.type === '城区' ? 'urban' : 'rural'}}">{{item.id}}</text>
        <view class="item-info">
          <text class="item-route">{{item.start}} - {{item.end}}</text>
          <text class="item-time">{{item.time}}</text>
        </view>
        <text class="item-price">{{item.price}}</text>
      </view>
    </view>
  </view>
</view>