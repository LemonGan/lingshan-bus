<!--index.wxml-->
<view class="container">
  <!-- 搜索框 -->
  <view class="search-box">
    <text class="search-icon">🔍</text>
    <input class="search-input" placeholder="搜索线路或站点" placeholder-class="search-placeholder" bindinput="onSearchInput" />
  </view>
  
  <!-- 热门线路 -->
  <view class="section-header">
    <text class="section-title">热门线路</text>
    <view class="section-line"></view>
  </view>
  
  <view class="line-grid">
    <view class="line-card" wx:for="{{hotLines}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <view class="line-number-row">
        <text class="line-number">{{item.number}}</text>
      </view>
      <text class="line-name">{{item.name}}</text>
      <text class="line-time">首班 {{item.firstBus}} - 末班 {{item.lastBus}}</text>
    </view>
  </view>
  
  <!-- 分类标签 -->
  <view class="section-header" style="margin-top:40rpx;">
    <text class="section-title">线路分类</text>
    <view class="section-line"></view>
  </view>
  
  <view class="category-list">
    <view class="category-item" bindtap="goToList" data-type="城区">
      <text class="category-name">城区公交</text>
      <text class="category-desc">2元一票制</text>
    </view>
    <view class="category-item" bindtap="goToList" data-type="城乡">
      <text class="category-name">城乡公交</text>
      <text class="category-desc">分段计费</text>
    </view>
    <view class="category-item" bindtap="goToList" data-type="跨县">
      <text class="category-name">跨县公交</text>
      <text class="category-desc">分段计费</text>
    </view>
  </view>
</view>