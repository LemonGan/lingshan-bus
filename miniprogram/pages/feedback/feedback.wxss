/* feedback.wxss */
.container { padding: 24rpx; }

.header { text-align: center; padding: 30rpx 0 40rpx; }
.header-icon { font-size: 64rpx; }
.header-title {
  font-size: var(--font-xxl); font-weight: 700;
  color: var(--color-text-primary); margin-top: 12rpx;
}
.header-desc {
  font-size: var(--font-md); color: var(--color-text-hint);
  margin-top: 8rpx; line-height: 1.5;
}

.form-card {
  background: var(--color-card); border-radius: var(--radius-md);
  padding: 28rpx 24rpx; margin-bottom: 20rpx; box-shadow: var(--shadow-sm);
}
.form-card .form-label {
  font-size: var(--font-md); font-weight: 600;
  color: var(--color-text-primary); margin-bottom: 12rpx; display: block;
}
.form-card .required { color: var(--color-danger); }
.form-card .form-hint {
  font-size: var(--font-sm); color: #bbb; margin-bottom: 12rpx; display: block;
}

.form-textarea {
  width: 100%; min-height: 200rpx;
  font-size: var(--font-md); line-height: 1.6;
  background: #f8f9fa; border-radius: var(--radius-sm);
  padding: 20rpx; border: 1rpx solid var(--color-border);
  box-sizing: border-box; color: var(--color-text-primary);
}
.form-count {
  font-size: var(--font-xs); color: #ccc; text-align: right; margin-top: 6rpx;
}

.form-input {
  width: 100%; height: auto;
  font-size: var(--font-md); color: var(--color-text-primary);
  background: #f8f9fa; border-radius: var(--radius-sm);
  padding: 20rpx; border: 1rpx solid var(--color-border);
  box-sizing: border-box;
}

.submit-btn {
  width: 100%; background: var(--color-primary); color: #fff;
  font-size: var(--font-lg); font-weight: 600;
  border-radius: var(--radius-round);
  padding: 24rpx 0; margin-top: 20rpx; border: none;
  box-shadow: 0 4rpx 12rpx rgba(22,119,255,0.3);
  transition: opacity 0.2s;
}
.submit-btn:active { opacity: 0.85; }
.submit-btn[disabled] { background: #ccc; box-shadow: none; }

.success-box {
  display: flex; flex-direction: column; align-items: center;
  padding: 120rpx 0;
}
.success-icon { font-size: 80rpx; }
.success-text {
  font-size: var(--font-xl); font-weight: 600; color: var(--color-text-primary); margin-top: 20rpx;
}
.success-desc {
  font-size: var(--font-md); color: var(--color-text-hint); margin-top: 10rpx;
}
.success-actions { margin-top: 40rpx; display: flex; gap: 20rpx; }
.action-btn {
  background: var(--color-primary); color: #fff; font-size: var(--font-md);
  border-radius: var(--radius-round); padding: 16rpx 40rpx; border: none;
}
.action-btn.secondary {
  background: var(--color-card); color: var(--color-primary);
  border: 1rpx solid var(--color-primary);
}
