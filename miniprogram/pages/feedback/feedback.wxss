/* feedback.wxss */
page { background: #f5f7fa; min-height: 100vh; }
.container { min-height: 100vh; padding: 24rpx; padding-bottom: 130rpx; }

.header { text-align: center; padding: 30rpx 0; }
.header-title { font-size: 40rpx; font-weight: 700; color: #333; }
.header-desc { font-size: 26rpx; color: #999; margin-top: 10rpx; display: block; }

.form { margin-top: 20rpx; }
.form-group { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 20rpx; }
.form-label { font-size: 28rpx; font-weight: 600; color: #333; display: block; margin-bottom: 16rpx; }
.form-textarea {
  width: 100%; min-height: 200rpx; font-size: 28rpx;
  background: #f8f9fa; border-radius: 12rpx;
  padding: 20rpx; box-sizing: border-box;
}
.form-count { font-size: 22rpx; color: #ccc; text-align: right; display: block; margin-top: 8rpx; }
.form-input {
  width: 100%; font-size: 28rpx;
  background: #f8f9fa; border-radius: 12rpx;
  padding: 20rpx; box-sizing: border-box;
}
.form-hint { font-size: 22rpx; color: #bbb; margin-top: 8rpx; display: block; }

.submit-btn {
  width: 100%; background: #1677FF; color: #fff;
  font-size: 30rpx; border-radius: 50rpx;
  padding: 24rpx 0; margin-top: 20rpx;
  border: none;
}
.submit-btn[disabled] { background: #ccc; }

.success-box {
  display: flex; flex-direction: column; align-items: center;
  padding: 100rpx 0;
}
.success-icon { font-size: 80rpx; }
.success-text { font-size: 36rpx; font-weight: 600; color: #333; margin-top: 20rpx; }
.success-desc { font-size: 26rpx; color: #999; margin-top: 10rpx; }
.success-actions { margin-top: 40rpx; display: flex; gap: 20rpx; }
.action-btn {
  background: #1677FF; color: #fff; font-size: 28rpx;
  border-radius: 50rpx; padding: 16rpx 40rpx; border: none;
}
.action-btn.secondary { background: #fff; color: #1677FF; border: 1rpx solid #1677FF; }

/* 悬浮返回按钮 */
.back-btn {
  position: fixed; left: 30rpx; bottom: 40rpx;
  width: 100rpx; height: 100rpx;
  background: #1677FF; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(22,119,255,0.4);
  z-index: 200;
}
.back-icon { font-size: 48rpx; }

/* 底部导航 */
.bottom-nav {
  position: fixed; left: 0; right: 0; bottom: 0;
  display: flex; background: #fff;
  border-top: 1rpx solid #eee;
  padding: 16rpx 0;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  z-index: 100;
}
.nav-item {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  color: #999;
}
.nav-item.active { color: #1677FF; }
.nav-icon { font-size: 40rpx; }
.nav-text { font-size: 22rpx; margin-top: 4rpx; }
