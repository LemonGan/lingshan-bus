/* feedback.wxss */
page { background: #f5f7fa; min-height: 100vh; }
.container { padding: 24rpx; }

.header { text-align: center; padding: 30rpx 0; }
.header-title { font-size: 40rpx; font-weight: 700; color: #333; }
.header-desc { font-size: 26rpx; color: #999; margin-top: 10rpx; display: block; line-height: 1.5; }

.form-group {
  background: #fff; border-radius: 16rpx; padding: 28rpx 24rpx;
  margin-bottom: 20rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.form-label { font-size: 28rpx; font-weight: 600; color: #333; display: block; margin-bottom: 16rpx; }
.form-textarea {
  display: block; width: 100%; min-height: 200rpx; font-size: 28rpx;
  background: #f8f9fa; border-radius: 12rpx;
  padding: 20rpx; border: 1rpx solid #eee;
  box-sizing: border-box;
}
.form-count { font-size: 22rpx; color: #ccc; text-align: right; display: block; margin-top: 8rpx; }
.form-input {
  display: block; width: 100%; font-size: 28rpx;
  background: #f8f9fa; border-radius: 12rpx;
  padding: 20rpx; border: 1rpx solid #eee;
  box-sizing: border-box;
}
.form-hint { font-size: 22rpx; color: #bbb; display: block; margin-top: 8rpx; }

.submit-btn {
  display: block; width: 100%; background: #1677FF; color: #fff;
  font-size: 30rpx; font-weight: 600; border-radius: 50rpx;
  padding: 24rpx 0; margin-top: 20rpx; border: none;
  box-shadow: 0 4rpx 12rpx rgba(22,119,255,0.3);
  text-align: center;
}
.submit-btn[disabled] { background: #ccc; box-shadow: none; }

.success-box {
  display: flex; flex-direction: column; align-items: center;
  padding: 120rpx 0;
}
.success-icon { font-size: 80rpx; }
.success-text { font-size: 36rpx; font-weight: 600; color: #333; margin-top: 20rpx; }
.success-desc { font-size: 26rpx; color: #999; margin-top: 10rpx; }
.success-actions { margin-top: 40rpx; display: flex; gap: 20rpx; }
.action-btn {
  background: #1677FF; color: #fff; font-size: 28rpx;
  border-radius: 50rpx; padding: 16rpx 40rpx; border: none;
}
.action-btn.secondary { background: #fff; color: #1677FF; border: 1rpx solid #1677FF; }
